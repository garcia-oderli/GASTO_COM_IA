 // ─── Projeção ─────────────────────────────────────────────────────
 /**
- * predictSpending: projeta o gasto total do mês com base na média diária atual.
+ * predictSpending: projeta o gasto do mês. A média diária vem dos últimos
+ * 90 dias (janela estável) — evita explodir a projeção no começo do mês,
+ * quando 1 ou 2 dias de gasto seriam multiplicados pelo mês inteiro.
+ * Projeção = já gasto no mês + ritmo dos 90 dias × dias que faltam.
  */
 function predictSpending() {
   const now = new Date();
   const dayOfMonth = now.getDate();
   const daysInMonth = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
-  const monthExp = getMonthExpenses();
-  if (!monthExp.length) return null;
-  const currentTotal = monthExp.reduce((s,e)=>s+e.valor,0);
-  const dailyAvg = currentTotal / dayOfMonth;
-  const projected = dailyAvg * daysInMonth;
   const remaining = daysInMonth - dayOfMonth;
-  return { projected, dailyAvg, remaining, currentTotal, daysInMonth, dayOfMonth };
+
+  // Gasto real já lançado neste mês
+  const currentTotal = getMonthExpenses().reduce((s,e)=>s+e.valor,0);
+
+  // Janela móvel de 90 dias para a média diária
+  const WINDOW = 90;
+  const cutoff = new Date(now.getFullYear(), now.getMonth(), now.getDate() - WINDOW);
+  let recentTotal = 0, earliest = now;
+  expenses.forEach(e => {
+    const d = parseExpenseDate(e.data);
+    if (d >= cutoff && d <= now) {
+      recentTotal += e.valor;
+      if (d < earliest) earliest = d;
+    }
+  });
+  if (recentTotal === 0) return null;
+
+  // Divide pelos dias de histórico realmente disponíveis (não sempre 90),
+  // para não subestimar o ritmo de uma conta nova.
+  const daysSpan = Math.min(WINDOW, Math.max(1, Math.round((now - earliest)/86400000) + 1));
+  const dailyAvg = recentTotal / daysSpan;
+
+  const projected = currentTotal + dailyAvg * remaining;
+  return { projected, dailyAvg, remaining, currentTotal, daysInMonth, dayOfMonth, windowDays: daysSpan };
 }
 
